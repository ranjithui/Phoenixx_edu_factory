# Copy this file to ".env" and fill in your MySQL details.
# On GoDaddy shared hosting DB_HOST is usually "localhost".

DB_HOST=localhost
DB_NAME=phoenixx_tasks
DB_USER=phoenixx_app
DB_PASS=CHANGE_ME

# App
APP_NAME=Phoenixx Task Manager
PORT=3000

# Secret used to sign session cookies — set to a long random string.
SESSION_SECRET=change-this-to-a-long-random-string
